{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "./.github/hooks/context-mode.sh pretooluse",
        "windows": "cmd /d /c .\\.github\\hooks\\git-bash.cmd .\\.github\\hooks\\context-mode.sh pretooluse"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "./.github/hooks/context-mode.sh posttooluse",
        "windows": "cmd /d /c .\\.github\\hooks\\git-bash.cmd .\\.github\\hooks\\context-mode.sh posttooluse"
      },
      {
        "type": "command",
        "command": "node ./.github/hooks/evo-lite-hook.js posttooluse"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "./.github/hooks/context-mode.sh precompact",
        "windows": "cmd /d /c .\\.github\\hooks\\git-bash.cmd .\\.github\\hooks\\context-mode.sh precompact"
      },
      {
        "type": "command",
        "command": "node ./.github/hooks/evo-lite-hook.js precompact"
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "./.github/hooks/context-mode.sh sessionstart",
        "windows": "cmd /d /c .\\.github\\hooks\\git-bash.cmd .\\.github\\hooks\\context-mode.sh sessionstart"
      },
      {
        "type": "command",
        "command": "node ./.github/hooks/evo-lite-hook.js sessionstart"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node ./.github/hooks/evo-lite-hook.js stop"
      }
    ]
  }
}